# Nexus City OS — docker compose environment (copy to .env; .env is git-ignored)

# --- Data feeds (optional) ---------------------------------------------------
WSDOT_ACCESS_CODE=

# --- History retention (days; pilots running a 60-day Decision Audit set 60+) -
NEXUS_HISTORY_RETENTION_DAYS=7

# --- Certificate signing key (ADR-002; hex, distinct from the auth key) -------
# Unset → generated once and persisted in the Store kv. Set to pin/rotate
# externally (e.g. KMS-managed). NEVER reuse the auth signing key.
NEXUS_CERT_KEY=

# --- LLM gateway (optional — deterministic expert system without it) ---------
NEXUS_LLM_BASE_URL=
NEXUS_LLM_API_KEY=

# --- Cloudflare Access — the only sign-in path (see CLOUDFLARE_ACCESS_SETUP.md) -
NEXUS_CF_ACCESS_TEAM_DOMAIN=aindoori.cloudflareaccess.com
# Comma-separated when the hostname carries a second, path-scoped Access
# application (e.g. console root + /community, each with its own audience).
NEXUS_CF_ACCESS_AUD=
NEXUS_CF_ACCESS_ADMINS=
NEXUS_CF_ACCESS_DEFAULT_ROLE=viewer
# Comma-separated civilian (Community Watch) emails.
NEXUS_CF_ACCESS_CITIZENS=
# Service-token map for machine/MCP clients: "<client-id>:<role>", comma-
# separated for multiple tokens. Unmapped tokens default to viewer; a
# service principal is never mapped to citizen.
NEXUS_CF_ACCESS_SERVICE_ROLES=

# --- Offline dev identity (NOT for production) --------------------------------
# Only used when no NEXUS_CF_ACCESS_* is configured (e.g. --sim, local dev).
# "email:role" — injected as the acting principal for every request, no
# login/tokens involved. Refused (server won't start) if Cloudflare Access
# IS configured, and required if it is NOT — never fails open.
NEXUS_DEV_IDENTITY=

# --- Public marketing subdomain (Host-based routing) --------------------------
NEXUS_LANDING_HOST=nexuscity.aindoori.com
NEXUS_CONSOLE_URL=https://nexus.aindoori.com/

# --- Tunnel sidecar -----------------------------------------------------------
# Host directory holding cert.pem + <tunnel-id>.json (default ~/.cloudflared).
# On Windows use forward slashes, e.g. C:/Users/you/.cloudflared
CLOUDFLARED_DIR=