# Nexus City OS — docker compose environment (copy to .env; .env is git-ignored)

# --- Data feeds (optional) ---------------------------------------------------
WSDOT_ACCESS_CODE=

# --- LLM gateway (optional — deterministic expert system without it) ---------
NEXUS_LLM_BASE_URL=
NEXUS_LLM_API_KEY=

# --- Cloudflare Access-only sign-in (see CLOUDFLARE_ACCESS_SETUP.md) ---------
NEXUS_CF_ACCESS_TEAM_DOMAIN=aindoori.cloudflareaccess.com
NEXUS_CF_ACCESS_AUD=
NEXUS_CF_ACCESS_ADMINS=
NEXUS_CF_ACCESS_DEFAULT_ROLE=viewer
NEXUS_DISABLE_DEMO_ACCOUNTS=1

# --- Public marketing subdomain (Host-based routing) --------------------------
NEXUS_LANDING_HOST=nexuscity.aindoori.com
NEXUS_CONSOLE_URL=https://nexus.aindoori.com/

# --- Tunnel sidecar -----------------------------------------------------------
# Host directory holding cert.pem + <tunnel-id>.json (default ~/.cloudflared).
# On Windows use forward slashes, e.g. C:/Users/you/.cloudflared
CLOUDFLARED_DIR=